{
  "schemaVersion": 1,
  "id": "hdr_mod",
  "version": "${version}",
  "name": "HDR Mod",
  "description": "Enable native HDR in Minecraft with Iris shaders.",
  "authors": [
    "rrtt217"
  ],
  "contributors": [
    "XgarhontX",
    "moyongxin",
    "CommandGenius"
  ],
  "contact": {
    "sources": "https://github.com/rrtt217/Minecraft-HDR-Mod"
  },
  "license": "MIT",
  "icon": "icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "xyz.rrtt217.HDRMod.fabric.HDRModFabric"
    ],
    "client": [
      "xyz.rrtt217.HDRMod.fabric.client.HDRModFabricClient"
    ],
    "modmenu":[
      "xyz.rrtt217.HDRMod.fabric.client.compat.HDRModModMenuIntegration"
    ]
  },
  "mixins": [
    "hdr_mod.mixins.json",
    "hdr_mod.fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.2",
    "minecraft": ">=26.1",
    "java": ">=25",
    "fabric-api": "*",
    "cloth-config":"*"
  },
  "suggests": {
    "iris": "*"
  }
}
